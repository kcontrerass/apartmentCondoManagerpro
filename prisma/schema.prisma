generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String        @id @default(cuid())
  email                String        @unique
  password             String
  name                 String
  phone                String?
  image                String?       @db.Text
  role                 Role          @default(RESIDENT)
  status               UserStatus    @default(ACTIVE)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  resetPasswordExpires DateTime?
  resetPasswordToken   String?       @unique
  complexId            String?       @map("complex_id")
  managedComplexes     Complex?
  reportedIncidents    Incident[]    @relation("Reporter")
  resolvedIncidents    Incident[]    @relation("Resolver")
  reservations         Reservation[]
  residentProfile      Resident?
  assignedComplex      Complex?      @relation("StaffComplex", fields: [complexId], references: [id])
  visitorLogs          VisitorLog[]  @relation("CreatedVisitorLogs")
  documents            Document[]    @relation("UserDocuments")
  incidentComments     IncidentComment[] @relation("CommentAuthor")
  polls                Poll[]            @relation("PollAuthor")
  votes                Vote[]
  settings             Json?


  @@index([complexId], map: "users_complex_id_fkey")
  @@map("users")
}

model Complex {
  id                 String                @id @default(cuid())
  name               String
  address            String                @db.Text
  type               ComplexType           @default(BUILDING)
  logoUrl            String?               @map("logo_url")
  bankAccount        String?               @map("bank_account")
  phone              String?
  settings           Json?
  platformPaidUntil  DateTime?             @map("platform_paid_until")
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  adminId            String?               @unique
  amenities     Amenity[]
  announcements Announcement[]
  admin         User?          @relation(fields: [adminId], references: [id])
  events        Event[]
  incidents     Incident[]
  invoices      Invoice[]
  services      Service[]
  units         Unit[]
  staff         User[]         @relation("StaffComplex")
  visitorLogs   VisitorLog[]
  documents     Document[]
  polls                Poll[]
  platformFeePayments  PlatformFeePayment[]


  @@map("complexes")
}

model PlatformFeePayment {
  id                   String                  @id @default(cuid())
  complexId            String                  @map("complex_id")
  amountCents          Int                     @map("amount_cents")
  currency             String                  @default("GTQ")
  status               PlatformFeeStatus       @default(PENDING)
  paymentMethod        PlatformFeePaymentMethod @default(CARD) @map("payment_method")
  recurrenteCheckoutId String?                 @map("recurrente_checkout_id")
  paidAt               DateTime?               @map("paid_at")
  periodMonths         Int                     @default(1) @map("period_months")
  invoiceId            String?                 @unique @map("invoice_id")
  /// Aceptación de términos legales al iniciar este cobro (auditoría).
  termsAcceptedAt      DateTime?               @map("terms_accepted_at")
  termsVersion         String?                 @map("terms_version")
  createdAt            DateTime                @default(now()) @map("created_at")
  updatedAt            DateTime                @updatedAt @map("updated_at")
  complex              Complex                 @relation(fields: [complexId], references: [id], onDelete: Cascade)
  invoice              Invoice?                @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([complexId], map: "platform_fee_payments_complex_id_idx")
  @@map("platform_fee_payments")
}

enum PlatformFeePaymentMethod {
  CARD
  BANK_TRANSFER
}

enum PlatformFeeStatus {
  PENDING
  PAID
  CANCELLED
}

/// Claves Recurrente del operador de la plataforma (cobros de suscripción). Editables por súper admin; el .env actúa como respaldo si faltan en BD.
model PlatformRecurrenteSettings {
  id                       String    @id @default("default")
  publicKey                String?   @map("public_key") @db.Text
  secretKey                String?   @map("secret_key") @db.Text
  webhookSecret            String?   @map("webhook_secret") @db.Text
  bankTransferInstructions String?   @map("bank_transfer_instructions") @db.Text
  subscriptionPriceGtq     Decimal?  @map("subscription_price_gtq") @db.Decimal(10, 2)
  subscriptionPeriodMonths Int?    @map("subscription_period_months")
  /// Días de gracia tras vencer platform_paid_until antes de bloquear el complejo (0 = mismo día).
  subscriptionGraceDays    Int?      @map("subscription_grace_days")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  @@map("platform_recurrente_settings")
}

model Unit {
  id           String        @id @default(cuid())
  number       String
  type         String?
  bedrooms     Int           @default(1)
  bathrooms    Float         @default(1)
  area         Float?
  status       UnitStatus    @default(VACANT)
  complexId    String        @map("complex_id")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  parkingSpots Int           @default(0) @map("parking_spots")
  incidents    Incident[]
  invoices     Invoice[]
  residents    Resident[]
  services     UnitService[]
  complex      Complex       @relation(fields: [complexId], references: [id], onDelete: Cascade)
  visitorLogs  VisitorLog[]

  @@unique([complexId, number])
  @@map("units")
}

model Resident {
  id                      String       @id @default(cuid())
  type                    ResidentType @default(TENANT)
  startDate               DateTime     @map("start_date")
  endDate                 DateTime?    @map("end_date")
  emergencyContact        Json?        @map("emergency_contact")
  isAirbnb                Boolean      @default(false) @map("is_airbnb")
  airbnbStartDate         DateTime?    @map("airbnb_start_date")
  airbnbEndDate           DateTime?    @map("airbnb_end_date")
  airbnbGuestName         String?      @map("airbnb_guest_name")
  airbnbReservationCode   String?      @map("airbnb_reservation_code")
  airbnbGuestPhone        String?      @map("airbnb_guest_phone")
  airbnbGuestIdentification String?    @map("airbnb_guest_identification")
  userId                  String       @unique @map("user_id")
  unitId                  String       @map("unit_id")
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
  unit                    Unit         @relation(fields: [unitId], references: [id], onDelete: Cascade)
  user                    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([unitId], map: "residents_unit_id_fkey")
  @@map("residents")
}

model Amenity {
  id              String        @id @default(cuid())
  name            String
  description     String?       @db.Text
  type            AmenityType   @default(OTHER)
  capacity        Int?
  operatingHours  Json?         @map("operating_hours")
  costPerDay      Decimal?      @map("cost_per_day") @db.Decimal(10, 2)
  costPerHour     Decimal?      @map("cost_per_hour") @db.Decimal(10, 2)
  securityDeposit Decimal?      @map("security_deposit") @db.Decimal(10, 2)
  complexId       String        @map("complex_id")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  requiresPayment Boolean       @default(false) @map("requires_payment")
  complex         Complex       @relation(fields: [complexId], references: [id], onDelete: Cascade)
  reservations    Reservation[]

  @@index([complexId], map: "amenities_complex_id_fkey")
  @@map("amenities")
}

model Reservation {
  id              String            @id @default(cuid())
  startTime       DateTime          @map("start_date_time")
  endTime         DateTime          @map("end_date_time")
  status          ReservationStatus @default(PENDING)
  notes           String?           @db.Text
  totalCost       Decimal?          @map("total_cost") @db.Decimal(10, 2)
  depositAmount   Decimal?          @map("deposit_amount") @db.Decimal(10, 2)
  depositStatus   DepositStatus     @default(NONE) @map("deposit_status")
  userId          String            @map("user_id")
  amenityId       String            @map("amenity_id")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  invoiceId       String?           @unique @map("invoice_id")
  paymentMethod   PaymentMethod?    @map("payment_method")
  refundMethod    PaymentMethod?    @map("refund_method")
  amenity         Amenity           @relation(fields: [amenityId], references: [id], onDelete: Cascade)
  invoice         Invoice?          @relation(fields: [invoiceId], references: [id])
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([amenityId], map: "reservations_amenity_id_fkey")
  @@index([userId], map: "reservations_user_id_fkey")
  @@map("reservations")
}

enum DepositStatus {
  NONE
  PENDING
  PAID
  REFUNDED
  RETAINED
}

model Service {
  id           String           @id @default(cuid())
  name         String
  description  String?          @db.Text
  basePrice    Decimal          @map("base_price") @db.Decimal(10, 2)
  frequency    ServiceFrequency @default(MONTHLY)
  complexId    String           @map("complex_id")
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  hasQuantity  Boolean          @default(false)
  isRequired   Boolean          @default(false)
  complex      Complex          @relation(fields: [complexId], references: [id], onDelete: Cascade)
  unitServices UnitService[]

  @@index([complexId], map: "services_complex_id_fkey")
  @@map("services")
}

model UnitService {
  id          String            @id @default(cuid())
  customPrice Decimal?          @map("custom_price") @db.Decimal(10, 2)
  status      UnitServiceStatus @default(ACTIVE)
  serviceId   String            @map("service_id")
  unitId      String            @map("unit_id")
  startDate   DateTime          @default(now()) @map("start_date")
  endDate     DateTime?         @map("end_date")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  quantity    Int               @default(1)
  service     Service           @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  unit        Unit              @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([unitId, serviceId])
  @@index([serviceId], map: "unit_services_service_id_fkey")
  @@map("unit_services")
}

model Invoice {
  id            String          @id @default(cuid())
  number        String          @unique
  month         Int
  year          Int
  dueDate       DateTime        @map("due_date")
  totalAmount   Decimal         @map("total_amount") @db.Decimal(10, 2)
  status        InvoiceStatus   @default(PENDING)
  category      InvoiceCategory @default(UNIT_BILLING) @map("category")
  unitId        String?         @map("unit_id")
  complexId     String          @map("complex_id")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  paymentMethod PaymentMethod? @map("payment_method")
  /// Método elegido por el residente antes de que staff o el mismo residente ejecuten el pago.
  paymentMethodIntent PaymentMethod? @map("payment_method_intent")
  items                InvoiceItem[]
  complex              Complex             @relation(fields: [complexId], references: [id], onDelete: Cascade)
  unit                 Unit?               @relation(fields: [unitId], references: [id], onDelete: Cascade)
  reservation          Reservation?
  platformFeePayment   PlatformFeePayment?

  @@index([complexId], map: "invoices_complex_id_fkey")
  @@index([unitId], map: "invoices_unit_id_fkey")
  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String   @map("invoice_id")
  description String
  amount      Decimal  @db.Decimal(10, 2)
  serviceId   String?  @map("service_id")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId], map: "invoice_items_invoice_id_fkey")
  @@map("invoice_items")
}

model VisitorLog {
  id            String        @id @default(cuid())
  visitorName   String        @map("visitor_name")
  visitorId     String?       @map("visitor_id_card")
  reason        String?       @db.Text
  status        VisitorStatus @default(SCHEDULED)
  entryTime     DateTime?     @map("entry_time")
  exitTime      DateTime?     @map("exit_time")
  scheduledDate DateTime      @map("scheduled_date")
  unitId        String        @map("unit_id")
  complexId     String        @map("complex_id")
  createdById   String        @map("created_by_id")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  complex       Complex       @relation(fields: [complexId], references: [id], onDelete: Cascade)
  createdBy     User          @relation("CreatedVisitorLogs", fields: [createdById], references: [id])
  unit          Unit          @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([complexId], map: "visitor_logs_complex_id_fkey")
  @@index([createdById], map: "visitor_logs_created_by_id_fkey")
  @@index([unitId], map: "visitor_logs_unit_id_fkey")
  @@map("visitor_logs")
}

model Announcement {
  id          String               @id @default(cuid())
  title       String
  content     String               @db.Text
  priority    AnnouncementPriority @default(NORMAL)
  complexId   String               @map("complex_id")
  targetRoles Json?                @map("target_roles")
  imageUrl    String?              @map("image_url")
  publishedAt DateTime?            @map("published_at")
  expiresAt   DateTime?            @map("expires_at")
  authorId    String               @map("author_id")
  authorName  String               @map("author_name")
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  complex     Complex              @relation(fields: [complexId], references: [id], onDelete: Cascade)

  @@index([complexId])
  @@index([publishedAt])
  @@map("announcements")
}

model Event {
  id            String      @id @default(cuid())
  title         String
  description   String      @db.Text
  complexId     String      @map("complex_id")
  location      String?
  eventDate     DateTime    @map("event_date")
  startTime     DateTime    @map("start_time")
  endTime       DateTime    @map("end_time")
  imageUrl      String?     @map("image_url")
  organizerId   String      @map("organizer_id")
  organizerName String      @map("organizer_name")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  maxAttendees  Int?        @map("max_attendees")
  rsvps         EventRSVP[]
  complex       Complex     @relation(fields: [complexId], references: [id], onDelete: Cascade)

  @@index([complexId])
  @@index([eventDate])
  @@map("events")
}

model EventRSVP {
  id        String     @id @default(cuid())
  eventId   String     @map("event_id")
  userId    String     @map("user_id")
  status    RSVPStatus
  guests    Int        @default(0)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  event     Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@map("event_rsvps")
}

model Incident {
  id          String           @id @default(cuid())
  title       String
  description String           @db.Text
  status      IncidentStatus   @default(REPORTED)
  priority    IncidentPriority @default(MEDIUM)
  type        IncidentType     @default(OTHER)
  complexId   String           @map("complex_id")
  unitId      String?          @map("unit_id")
  reporterId  String           @map("reporter_id")
  resolverId  String?          @map("resolver_id")
  imageUrl    String?          @map("image_url")
  location    String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  complex     Complex          @relation(fields: [complexId], references: [id], onDelete: Cascade)
  reporter    User             @relation("Reporter", fields: [reporterId], references: [id])
  resolver    User?            @relation("Resolver", fields: [resolverId], references: [id])
  unit        Unit?            @relation(fields: [unitId], references: [id])
  comments    IncidentComment[]

  @@index([complexId])
  @@index([reporterId])
  @@index([resolverId], map: "incidents_resolver_id_fkey")
  @@index([unitId], map: "incidents_unit_id_fkey")
  @@map("incidents")
}

model IncidentComment {
  id         String   @id @default(cuid())
  content    String   @db.Text
  incidentId String   @map("incident_id")
  authorId   String   @map("author_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  author   User     @relation("CommentAuthor", fields: [authorId], references: [id])

  @@index([incidentId])
  @@index([authorId])
  @@map("incident_comments")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  BOARD_OF_DIRECTORS
  GUARD
  RESIDENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ComplexType {
  BUILDING
  RESIDENTIAL
  CONDO
  SHOPPING_CENTER
}

enum UnitStatus {
  OCCUPIED
  VACANT
  MAINTENANCE
}

enum ResidentType {
  OWNER
  TENANT
}

enum ReservationStatus {
  PENDING
  APPROVED
  CANCELLED
  REJECTED
  COMPLETED
  PROCESSING
}

enum PaymentMethod {
  CARD
  CASH
  TRANSFER
}

enum AmenityType {
  POOL
  GYM
  CLUBHOUSE
  COURT
  BBQ
  OTHER
}

enum VisitorStatus {
  SCHEDULED
  ARRIVED
  DEPARTED
  CANCELLED
}

enum ServiceFrequency {
  ONCE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum UnitServiceStatus {
  ACTIVE
  INACTIVE
}

enum InvoiceCategory {
  UNIT_BILLING
  PLATFORM_SUBSCRIPTION
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
  PROCESSING
}

enum AnnouncementPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum RSVPStatus {
  GOING
  NOT_GOING
  MAYBE
}

enum IncidentStatus {
  REPORTED
  IN_PROGRESS
  RESOLVED
  CANCELLED
}

enum IncidentPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum IncidentType {
  MAINTENANCE
  SECURITY
  NOISE
  CLEANING
  OTHER
}

model Document {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  category    String?
  fileUrl     String   @map("file_url")
  fileSize    Int?     @map("file_size")
  fileType    String?  @map("file_type")
  complexId   String   @map("complex_id")
  authorId    String   @map("author_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  complex     Complex  @relation(fields: [complexId], references: [id], onDelete: Cascade)
  author      User     @relation("UserDocuments", fields: [authorId], references: [id])

  @@index([complexId])
  @@index([authorId])
  @@map("documents")
}

model Poll {
  id          String       @id @default(cuid())
  title       String
  description String?      @db.Text
  status      PollStatus   @default(OPEN)
  expiresAt   DateTime?    @map("expires_at")
  complexId   String       @map("complex_id")
  authorId    String       @map("author_id")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  complex     Complex      @relation(fields: [complexId], references: [id], onDelete: Cascade)
  author      User         @relation("PollAuthor", fields: [authorId], references: [id])
  options     PollOption[]
  votes       Vote[]

  @@index([complexId])
  @@map("polls")
}

model PollOption {
  id     String @id @default(cuid())
  text   String
  pollId String @map("poll_id")
  poll   Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes  Vote[]

  @@map("poll_options")
}

model Vote {
  id        String   @id @default(cuid())
  pollId    String   @map("poll_id")
  optionId  String   @map("option_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  poll   Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId]) // Una persona, un voto por encuesta
  @@index([pollId])
  @@index([userId])
  @@map("votes")
}

enum PollStatus {
  OPEN
  CLOSED
}
